#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path


def import_atspi():
    if "DBUS_SESSION_BUS_ADDRESS" not in os.environ:
        for environ in Path("/proc").glob("[0-9]*/environ"):
            try:
                if environ.stat().st_uid != os.getuid():
                    continue
                values = dict(
                    item.split("=", 1)
                    for item in environ.read_bytes().decode(errors="ignore").split("\0")
                    if "=" in item
                )
                if values.get("DISPLAY") == os.environ.get("DISPLAY") and values.get("DBUS_SESSION_BUS_ADDRESS"):
                    os.environ["DBUS_SESSION_BUS_ADDRESS"] = values["DBUS_SESSION_BUS_ADDRESS"]
                    break
            except (OSError, ValueError):
                continue
    import pyatspi
    return pyatspi


def states(pyatspi, node):
    try:
        return [pyatspi.stateToString(value) for value in node.getState().getStates()]
    except Exception:
        return []


def actions(node):
    try:
        interface = node.queryAction()
        return [interface.getName(index) for index in range(interface.nActions)]
    except Exception:
        return []


def describe(pyatspi, node, path):
    try:
        name = node.name or ""
    except Exception:
        name = ""
    try:
        role = node.getRoleName() or ""
    except Exception:
        role = ""
    try:
        description = node.description or ""
    except Exception:
        description = ""
    item = {
        "path": path,
        "name": name,
        "role": role,
        "description": description,
        "states": states(pyatspi, node),
        "actions": actions(node),
    }
    try:
        extents = node.queryComponent().getExtents(pyatspi.DESKTOP_COORDS)
        if extents.width > 0 and extents.height > 0:
            item["bounds"] = {
                "left": extents.x,
                "top": extents.y,
                "width": extents.width,
                "height": extents.height,
            }
    except Exception:
        pass
    return item


def walk(pyatspi, node, path=(), depth=0, max_depth=12):
    yield node, path
    if depth >= max_depth:
        return
    try:
        count = node.childCount
    except Exception:
        return
    for index in range(count):
        try:
            child = node.getChildAtIndex(index)
            yield from walk(pyatspi, child, (*path, index), depth + 1, max_depth)
        except Exception:
            continue


def matches(node, options):
    try:
        name = (node.name or "").casefold()
        role = (node.getRoleName() or "").casefold()
    except Exception:
        return False
    wanted_name = str(options.get("name", "")).casefold()
    wanted_role = str(options.get("role", "")).casefold()
    if wanted_name:
        if options.get("exact") and name != wanted_name:
            return False
        if not options.get("exact") and wanted_name not in name:
            return False
    if wanted_role and wanted_role != role:
        return False
    return bool(wanted_name or wanted_role)


def screen_size():
    try:
        output = subprocess.check_output(["xdpyinfo"], stderr=subprocess.DEVNULL, text=True)
        match = re.search(r"dimensions:\s+(\d+)x(\d+)", output)
        if match:
            return int(match.group(1)), int(match.group(2))
    except (OSError, subprocess.SubprocessError):
        pass
    return None


def is_on_screen(pyatspi, node, size):
    if size is None:
        return True
    try:
        extents = node.queryComponent().getExtents(pyatspi.DESKTOP_COORDS)
        return (
            extents.width <= 0
            or extents.height <= 0
            or (
                extents.x < size[0]
                and extents.y < size[1]
                and extents.x + extents.width > 0
                and extents.y + extents.height > 0
            )
        )
    except Exception:
        return True


def find(pyatspi, options):
    desktop = pyatspi.Registry.getDesktop(0)
    size = screen_size()
    found = []
    requested_nth = int(options.get("nth", 0))
    default_limit = requested_nth + 1 if requested_nth >= 0 else 100
    limit = max(default_limit, int(options.get("limit", default_limit)))
    for node, path in walk(pyatspi, desktop, max_depth=int(options.get("max_depth", 12))):
        if matches(node, options):
            if not options.get("include_offscreen", False) and not is_on_screen(pyatspi, node, size):
                continue
            found.append((node, path))
            if len(found) >= limit:
                break
    nth = requested_nth
    nth = nth if nth >= 0 else len(found) + nth
    if not 0 <= nth < len(found):
        raise ValueError(f"accessible element not found: {options}")
    node, path = found[nth]
    return node, describe(pyatspi, node, path), len(found)


def state_matches(pyatspi, node, options):
    wanted = str(options.get("state", "")).casefold().replace("_", "-")
    if not wanted:
        return True
    present = wanted in {
        value.casefold().replace("_", "-") for value in states(pyatspi, node)
    }
    return present is bool(options.get("value", True))


def assert_element(pyatspi, options):
    node, result, count = find(pyatspi, options)
    if not state_matches(pyatspi, node, options):
        raise ValueError(
            f"accessible element state mismatch: {options.get('state')!r}"
        )
    result["matches"] = count
    return node, result




def main():
    pyatspi = import_atspi()
    action = sys.argv[1] if len(sys.argv) > 1 else "probe"
    if action == "probe":
        desktop = pyatspi.Registry.getDesktop(0)
        print(json.dumps({"desktop": desktop.name, "applications": desktop.childCount}))
        return
    options = json.load(sys.stdin) if not sys.stdin.isatty() else {}
    if action == "list":
        desktop = pyatspi.Registry.getDesktop(0)
        limit = int(options.get("limit", 500))
        result = []
        for node, path in walk(pyatspi, desktop, max_depth=int(options.get("max_depth", 8))):
            item = describe(pyatspi, node, path)
            if item["name"] or item["role"]:
                result.append(item)
            if len(result) >= limit:
                break
        print(json.dumps({"elements": result, "truncated": len(result) >= limit}))
        return
    node, result = assert_element(pyatspi, options)
    if action in {"find", "assert", "read"}:
        if action == "read":
            try:
                text = node.queryText()
                result["text"] = text.getText(0, text.characterCount)
            except Exception:
                pass
        print(json.dumps(result))
        return
    if action == "invoke":
        method = str(options.get("method", "pointer")).casefold()
        if method == "native":
            interface = node.queryAction()
            wanted = str(options.get("action", "")).casefold()
            index = 0
            if wanted:
                available = [interface.getName(value) for value in range(interface.nActions)]
                matching = [value for value, name in enumerate(available) if wanted in name.casefold()]
                if not matching:
                    raise ValueError(f"accessible action not found: {wanted!r}; available: {available}")
                index = matching[0]
            if not interface.doAction(index):
                raise RuntimeError("accessible action returned false")
            result["invoked"] = interface.getName(index)
        else:
            extents = node.queryComponent().getExtents(pyatspi.DESKTOP_COORDS)
            if extents.width <= 0 or extents.height <= 0:
                raise RuntimeError("accessible element has no clickable bounds")
            x = extents.x + extents.width // 2
            y = extents.y + extents.height // 2
            pyatspi.Registry.generateMouseEvent(x, y, "b1c")
            result["invoked"] = "pointer"
            result["point"] = {"x": x, "y": y}
        time.sleep(float(options.get("settle", 0.3)))
    elif action == "focus":
        if not node.queryComponent().grabFocus():
            raise RuntimeError("accessible focus returned false")
        result["focused"] = True
    elif action == "set-value":
        if "text" in options:
            node.queryEditableText().setTextContents(str(options["text"]))
            result["characters"] = len(str(options["text"]))
        else:
            value = node.queryValue()
            value.currentValue = float(options["value"])
            result["value"] = value.currentValue
    else:
        raise ValueError(f"unknown action: {action}")
    print(json.dumps(result))


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        print(json.dumps({"error": str(error)}), file=sys.stderr)
        raise SystemExit(1)

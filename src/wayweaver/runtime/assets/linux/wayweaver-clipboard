#!/usr/bin/env python3
import subprocess
import sys


def main():
    action = sys.argv[1] if len(sys.argv) > 1 else "read"
    if action == "read":
        process = subprocess.run(
            ["xclip", "-selection", "clipboard", "-o"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        if process.returncode:
            raise RuntimeError(process.stderr.decode(errors="replace").strip())
        sys.stdout.buffer.write(process.stdout)
        return
    if action != "write":
        raise ValueError(f"unknown action: {action}")
    process = subprocess.Popen(
        ["xclip", "-selection", "clipboard", "-i"],
        stdin=subprocess.PIPE,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    process.communicate(sys.stdin.buffer.read(), timeout=5)
    if process.returncode:
        raise RuntimeError(f"xclip exited {process.returncode}")


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        print(str(error), file=sys.stderr)
        raise SystemExit(1)

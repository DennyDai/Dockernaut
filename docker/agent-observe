#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
from pathlib import Path

HOME = Path(os.environ.get("HOME", "/home/vm"))
SCREENSHOT_DIR = HOME / ".agent" / "screenshots"
CURRENT = SCREENSHOT_DIR / "current.png"


def run(cmd, check=False):
    result = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=check)
    return result.stdout.strip()


def capture(path):
    path.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(["maim", str(path)], check=True)


def screen_size():
    out = run(["xdpyinfo"])
    for line in out.splitlines():
        line = line.strip()
        if line.startswith("dimensions:"):
            size = line.split()[1]
            width, height = size.split("x", 1)
            return {"width": int(width), "height": int(height)}
    return None


def active_window():
    wid = run(["xdotool", "getactivewindow"])
    if not wid:
        return None
    name = run(["xdotool", "getwindowname", wid])
    geom = run(["xdotool", "getwindowgeometry", "--shell", wid])
    parsed = {"id": wid, "title": name}
    for line in geom.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            if value.isdigit():
                parsed[key.lower()] = int(value)
            else:
                parsed[key.lower()] = value
    return parsed


def mouse_location():
    out = run(["xdotool", "getmouselocation", "--shell"])
    parsed = {}
    for line in out.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            parsed[key.lower()] = int(value) if value.isdigit() else value
    return parsed or None


def windows():
    out = run(["wmctrl", "-lG"])
    items = []
    for line in out.splitlines():
        parts = line.split(None, 7)
        if len(parts) < 8:
            continue
        wid, desktop, x, y, width, height, host, title = parts
        items.append({
            "id": wid,
            "desktop": int(desktop),
            "x": int(x),
            "y": int(y),
            "width": int(width),
            "height": int(height),
            "host": host,
            "title": title,
        })
    return items


def ocr(path):
    result = subprocess.run(["tesseract", str(path), "stdout"], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    return result.stdout.strip()


def main():
    parser = argparse.ArgumentParser(description="Capture desktop state for host-side agents.")
    parser.add_argument("--path", default=str(CURRENT), help="Screenshot path inside the VM")
    parser.add_argument("--ocr", action="store_true", help="Include OCR text from the screenshot")
    args = parser.parse_args()

    os.environ.setdefault("DISPLAY", ":1")
    os.environ.setdefault("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")

    screenshot = Path(args.path)
    capture(screenshot)
    payload = {
        "screenshot": str(screenshot),
        "host_path_hint": "${VM_HOME:-./homes/default}" + str(screenshot).replace(str(HOME), "", 1),
        "screen": screen_size(),
        "active_window": active_window(),
        "mouse": mouse_location(),
        "windows": windows(),
    }
    if args.ocr:
        payload["ocr"] = ocr(screenshot)
    print(json.dumps(payload, indent=2, sort_keys=True))


if __name__ == "__main__":
    main()

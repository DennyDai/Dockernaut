#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -lt 1 ]]; then
  printf 'usage: agent-type TEXT...\n' >&2
  exit 2
fi

export DISPLAY="${DISPLAY:-:1}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

text="$*"
xdotool type --clearmodifiers --delay "${AGENT_TYPE_DELAY:-15}" "${text}"

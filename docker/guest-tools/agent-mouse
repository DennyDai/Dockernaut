#!/usr/bin/env python3
import argparse
import math
import os
import random
import subprocess
import time


def xdotool(*args, capture=False):
    result = subprocess.run(
        ["xdotool", *map(str, args)],
        check=True,
        text=True,
        stdout=subprocess.PIPE if capture else subprocess.DEVNULL,
    )
    return result.stdout.strip() if capture else ""


def pointer_location():
    fields = {}
    for line in xdotool("getmouselocation", "--shell", capture=True).splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            fields[key] = int(value) if value.isdigit() else value
    return fields["X"], fields["Y"]


def display_size():
    width, height = xdotool("getdisplaygeometry", capture=True).split()
    return int(width), int(height)


def direct_move(x, y):
    xdotool("mousemove", x, y)


def human_move(x2, y2, duration_ms=None):
    x1, y1 = pointer_location()
    width, height = display_size()
    x2 = max(0, min(width - 1, x2))
    y2 = max(0, min(height - 1, y2))
    distance = math.hypot(x2 - x1, y2 - y1)
    if distance < 1:
        direct_move(x2, y2)
        return

    if duration_ms is None:
        baseline = max(180, min(900, 170 + distance * 0.55))
        duration_ms = round(baseline * random.uniform(0.85, 1.15))
    duration = max(1, duration_ms) / 1000
    steps = max(8, min(120, math.ceil(duration * 60)))
    delay = duration / steps

    dx, dy = x2 - x1, y2 - y1
    normal_x, normal_y = -dy / distance, dx / distance
    bend = random.uniform(-1, 1) * min(55, distance * 0.12)
    c1 = (x1 + dx * random.uniform(0.20, 0.38) + normal_x * bend, y1 + dy * random.uniform(0.20, 0.38) + normal_y * bend)
    c2 = (x1 + dx * random.uniform(0.62, 0.82) + normal_x * bend * 0.55, y1 + dy * random.uniform(0.62, 0.82) + normal_y * bend * 0.55)

    for step in range(1, steps + 1):
        raw = step / steps
        t = raw * raw * (3 - 2 * raw)
        inverse = 1 - t
        x = inverse**3 * x1 + 3 * inverse**2 * t * c1[0] + 3 * inverse * t**2 * c2[0] + t**3 * x2
        y = inverse**3 * y1 + 3 * inverse**2 * t * c1[1] + 3 * inverse * t**2 * c2[1] + t**3 * y2
        if step != steps:
            x += random.uniform(-0.7, 0.7)
            y += random.uniform(-0.7, 0.7)
        direct_move(round(max(0, min(width - 1, x))), round(max(0, min(height - 1, y))))
        time.sleep(delay * random.uniform(0.80, 1.20))

    direct_move(x2, y2)


def press(button):
    xdotool("mousedown", "--clearmodifiers", button)
    time.sleep(random.uniform(0.045, 0.130))
    xdotool("mouseup", button)


def add_position(parser):
    parser.add_argument("x", type=int)
    parser.add_argument("y", type=int)
    parser.add_argument("--duration-ms", type=int, help="Override randomized movement duration")


def main():
    os.environ.setdefault("DISPLAY", ":1")
    os.environ.setdefault("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")

    parser = argparse.ArgumentParser(description="Human-like mouse actions on the VM desktop.")
    commands = parser.add_subparsers(dest="action", required=True)

    move_parser = commands.add_parser("move", help="Move the pointer along a randomized curved path")
    add_position(move_parser)

    click_parser = commands.add_parser("click", help="Move naturally, then click")
    add_position(click_parser)
    click_parser.add_argument("button", type=int, nargs="?", default=1)

    double_parser = commands.add_parser("double-click", help="Move naturally, then double-click")
    add_position(double_parser)
    double_parser.add_argument("button", type=int, nargs="?", default=1)
    double_parser.add_argument("--interval-ms", type=int, default=120)

    down_parser = commands.add_parser("down", help="Press and hold a mouse button")
    down_parser.add_argument("button", type=int, nargs="?", default=1)

    up_parser = commands.add_parser("up", help="Release a mouse button")
    up_parser.add_argument("button", type=int, nargs="?", default=1)

    drag_parser = commands.add_parser("drag", help="Move naturally, hold, and drag along a curved path")
    drag_parser.add_argument("x1", type=int)
    drag_parser.add_argument("y1", type=int)
    drag_parser.add_argument("x2", type=int)
    drag_parser.add_argument("y2", type=int)
    drag_parser.add_argument("--button", type=int, default=1)
    drag_parser.add_argument("--duration-ms", type=int)

    scroll_parser = commands.add_parser("scroll", help="Scroll at the current or specified position")
    scroll_parser.add_argument("direction", choices=("up", "down", "left", "right"))
    scroll_parser.add_argument("amount", type=int, nargs="?", default=3)
    scroll_parser.add_argument("--x", type=int)
    scroll_parser.add_argument("--y", type=int)
    scroll_parser.add_argument("--duration-ms", type=int, help="Override movement duration")

    args = parser.parse_args()

    if args.action == "move":
        human_move(args.x, args.y, args.duration_ms)
    elif args.action == "click":
        human_move(args.x, args.y, args.duration_ms)
        time.sleep(random.uniform(0.035, 0.120))
        press(args.button)
    elif args.action == "double-click":
        human_move(args.x, args.y, args.duration_ms)
        time.sleep(random.uniform(0.035, 0.100))
        press(args.button)
        time.sleep(max(30, args.interval_ms) / 1000 * random.uniform(0.85, 1.15))
        press(args.button)
    elif args.action == "down":
        xdotool("mousedown", "--clearmodifiers", args.button)
    elif args.action == "up":
        xdotool("mouseup", args.button)
    elif args.action == "drag":
        human_move(args.x1, args.y1)
        time.sleep(random.uniform(0.040, 0.110))
        xdotool("mousedown", "--clearmodifiers", args.button)
        try:
            time.sleep(random.uniform(0.040, 0.100))
            human_move(args.x2, args.y2, args.duration_ms)
        finally:
            time.sleep(random.uniform(0.035, 0.090))
            xdotool("mouseup", args.button)
    elif args.action == "scroll":
        if (args.x is None) != (args.y is None):
            parser.error("scroll requires both --x and --y")
        if args.x is not None:
            human_move(args.x, args.y, args.duration_ms)
        button = {"up": 4, "down": 5, "left": 6, "right": 7}[args.direction]
        for _ in range(max(0, args.amount)):
            press(button)
            time.sleep(random.uniform(0.035, 0.110))


if __name__ == "__main__":
    main()
